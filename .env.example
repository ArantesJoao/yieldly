# Postgres connection string
DATABASE_URL="postgresql://user:password@host:5432/yieldly"

# Google OAuth client (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Email that is granted the `admin` role on first sign-in
ADMIN_EMAIL=""

# NextAuth (generate with `npx auth secret` or `openssl rand -base64 32`)
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3001"

# Optional: override the API base URL used by the HTTP client
# NEXT_PUBLIC_API_URL=""
